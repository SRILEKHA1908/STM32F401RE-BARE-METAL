#include "stm32f401xe.h"
#include "stdint.h"

// I2C EEPROM addresses
#define I2C_WRITE_ADDRESS (0xA0)
#define I2C_READ_ADDRESS  (0xA1)

// PINOUT
// PB8 - SCL
// PB9 - SDA
#define SM100KHz 80
// TPCLK => 16MHz => 1/16 => 0.0625 us => 62.5 ns

//USE CCR REGISTER => 503
// Standard mode
// Standard mode => 100KHz => 1/100 => 0.01 ms => 0.01 * 1000 * 1000 => 10000 ns
// THIGH =5000ns TLOW => 5000 ns
// THIGH => CCR * TPCLK
// CCR => THIGH / TPCLK => 5000 / 62.5 => 80
// TLOW => CCR * TPCLK
// CCR => TLOW / TPCLK => 5000 / 62.5 => 80

// Timing constants
#define SM100KHz 80

void I2C_CONFIGURATION();
void START();
void STOP();
void RESTART();
void WRITE_TO_EEPROM();
uint8_t READ_FROM_EEPROM();
void DELAY(uint32_t ms);

void I2C_CONFIGURATION()
{
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOBEN;

    GPIOB->MODER |= (0x1<< 19) | (0x1 << 17);
    GPIOB->MODER &= ~((0x1 << 18) | (0x1 << 16));

    GPIOB->OTYPER |= (0x1 << 8) | (0x1 << 9);//Open drain

    GPIOB->AFR[1] |= (0x4 << 0) | (0x4 << 4);

    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;
    I2C1->CR2 = (0x1 << 4);//Freq-16Mhz
    I2C1->CCR = SM100KHz;
    //SM Mode (Standard Mode) =>  Speed: Up to 100 kHz.
    //FM Mode (Fast Mode) => Speed: Up to 400 kHz.
    I2C1->CR1 |= I2C_CR1_PE;
}

void START()
{
    I2C1->CR1 |= I2C_CR1_START;
    while (!(I2C1->SR1 & I2C_SR1_SB));
}

void STOP()
{
    I2C1->CR1 |= I2C_CR1_STOP;
    while (I2C1->CR1 & I2C_CR1_STOP);
}

void RESTART()
{
    STOP();
    START();
}

void WRITE_TO_EEPROM()
{
    START();
    I2C1->DR = I2C_WRITE_ADDRESS;
    while (!(I2C1->SR1 & I2C_SR1_ADDR));


    I2C1->DR = 0x00;//high address
    while (!(I2C1->SR1 & I2C_SR1_BTF));

    I2C1->DR = 0x00;//Low address
    while (!(I2C1->SR1 & I2C_SR1_BTF));

    char a[]= "SRILEKHA";
    for(int i = 0; a[i]!='\0';i++)
    {
    	 I2C1->DR = a[i];
    	 while (!(I2C1->SR1 & I2C_SR1_BTF));
    	 I2C1->CR1 |=  I2C_CR1_ACK;
    	 I2C1->CR1 &= ~I2C_CR1_ACK;

    }

    STOP();
}


int main()
{
    I2C_CONFIGURATION();
    WRITE_TO_EEPROM();
    DELAY(100);
    while(1); // Infinite loop
}

void DELAY(uint32_t ms)
{
    uint32_t i, j;
    for (i = 0; i < ms; i++)
        for (j = 0; j < 16000; j++); // Delay loop
}
