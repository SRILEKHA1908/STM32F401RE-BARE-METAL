#include <stm32f401xe.h>
#define GPIOAEN  (1<<0)
#define GPIOCEN  (1<<2)

//button define
#define BUTTON   (1<<0)
#define BUTTON1  (1<<1)
#define BUTTON2  (1<<2)
#define BUTTON3  (1<<3)


void delay();


int main()
{
	RCC->AHB1ENR |= GPIOAEN;
	RCC->AHB1ENR |= GPIOCEN;

	GPIOA->MODER |= 0X5555;// OUTPUT

	GPIOC->MODER &=~(0X1<<0);// INPUT
	GPIOC->MODER &=~(0X1<<1);
	GPIOC->MODER &=~(0X1<<2);
	GPIOC->MODER &=~(0X1<<3);
	GPIOC->MODER &=~(0X1<<4);
	GPIOC->MODER &=~(0X1<<5);
	GPIOC->MODER &=~(0X1<<6);
	GPIOC->MODER &=~(0X1<<7);

	GPIOC->PUPDR |= (0X1<<0);//PC0 P-UP
	GPIOC->PUPDR |= (0X1<<2);//PC1 P-UP
	GPIOC->PUPDR |= (0X1<<5);//PC2 P-DO
	GPIOC->PUPDR |= (0X1<<7);//PC3 P-DO

	while(1)
	{
		if(!(GPIOC->IDR & BUTTON))//if((GPIOA->IDR & BUTTON)== 0)
		{
			GPIOA->ODR |= 0XFF;
		}

		else if(!(GPIOC->IDR & BUTTON1))//if((GPIOA->IDR & BUTTON)== 0)
		{
			int i;
			for(i=0;i<8;i++)
			{
				GPIOA->ODR = (1<<i);
				delay();//for(i=0;i<10000;i++);
				GPIOA->ODR = 0X00;
				delay();
			}
		}

		else if((GPIOC->IDR & BUTTON2))//if((GPIOA->IDR & BUTTON)== 0)
		{
			int i;
			for(i=7;i>=0;i--)
			{
				 GPIOA->ODR = (1<<i);
				 delay();//for(i=0;i<10000;i++);
				 GPIOA->ODR = 0X00;
				 delay();
			}
		}

		else if((GPIOC->IDR & BUTTON3))//if((GPIOA->IDR & BUTTON)== 0)
		{
			int i;
			for(i=0;i<8;i+=2)
			{

			    GPIOA->ODR = (1<<i) | (1<<(i+1));  // turn ON two LEDs
			    delay();
				GPIOA->ODR = 0X00;
			    delay();


			}
	    }
		else
		{
			GPIOA->ODR &= ~(0XFF);
		}
	}
}
void delay()
{
	int i,j;
for(i=0;i<10000;i++)
for(j=0;j<100;j++);
}
