void GPIOA_INIT()
{
	RCC->AHB1ENR |=(1<<0);

	GPIOA->MODER |= (1U<<15);
	GPIOA->MODER &= ~(1U<<14);

	GPIOA->MODER |= (1U<<13);
	GPIOA->MODER &= ~(1U<<12);

	GPIOA->MODER |= (1U<<11);
	GPIOA->MODER &= ~(1U<<10);

	GPIOA->MODER &= ~(1U<<9);
	GPIOA->MODER |= (1U<<8);

	GPIOA->AFR[0] |= 0x5UL<<28U;

	GPIOA->AFR[0] |= 0x5UL<<24;

	GPIOA->AFR[0] |= 0x5UL<<20;

}

void SPI1_MASTER_INIT()
{
	GPIOA_INIT();



	 RCC->APB2ENR |= SPI2EN;


	    SPI1->CR1 |= 0x08UL;


	    SPI1->CR1 |= MSTR;
	    SPI1->CR1 |= SPE;

}

void SPI_MO(uint8_t data)
{
    SPI1->DR = data;
    while (!(SPI1->SR & TXE)); // Wait until the transmit buffer is empty
    while (!(SPI1->SR & BUSY));
}


uint8_t SPI_MI()
{
	while(!(SPI1->SR & TXE));
	SPI1->DR = 0xFF;   // Dummy write

	while(!(SPI1->SR & RXNE));
	return SPI1->DR;
}

void SPI_BYTE_WRITE()
{
	    uint32_t i;
	    GPIOA->ODR |= (1<<4);//SS=1
		for(i=0;i<1000;i++);

		GPIOA->ODR &= ~(1<<4);//SS=0
		SPI_MO(0X06UL);
		GPIOA->ODR |= (1<<4);//SS=1
		for(i=0;i<1000;i++);

		GPIOA->ODR &= ~(1<<4);//SS=0
		SPI_MO(0X02UL);
		SPI_MO(0X00UL);
		SPI_MO(0X00UL);
		SPI_MO('S');
		for(int i=0;i<50000;i++);

	    GPIOA->ODR |= (1<<4);//SS=1
		for(i=0;i<1000;i++);
		GPIOA->ODR &= ~(1<<4);//SS=0

}

char SPI_BYTEREAD(){

        GPIOA->ODR |= (1<<4);

	    for (volatile int i = 0; i < 1000; i++);

	    GPIOA->ODR &= ~(1<<4);
	    SPI_MO(0x03UL);
	    SPI_MO(0x00UL);
	    SPI_MO(0x00UL);
	    SPI_MO(0x00);
	    char REC=SPI1->DR;
	    GPIOA->ODR |= (1<<4);
	    return REC;
}


