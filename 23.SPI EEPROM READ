void lcd_init()
{

	send_cmd(0x38);
	send_cmd(0x0E);
	send_cmd(0x01);// clear display screen
	send_cmd(0x06);
}
void send_cmd(char a)
{
	GPIOB->ODR = (GPIOB->ODR & 0xFF00) | a;
	GPIOB->ODR &=~ RS;//COMMAND
	GPIOB->ODR &=~ RW;//WRITE
	GPIOB->ODR |= EN;
	for(int i=0;i<1000;i++);
	GPIOB->ODR &=~ EN;
}

void send_data(char b)
{
	GPIOB->ODR = (GPIOB->ODR & 0xFF00) | b;
    GPIOB->ODR |= RS;
    GPIOB->ODR &=~ RW;
    GPIOB->ODR |= EN;
    for(int i=0;i<1000;i++);
    GPIOB->ODR &=~ EN;
}



void show_data(char s[])
{
	int k;
	for(k =0;s[k]!='\0';k++)
	{
		send_data(s[k]);
	}
}

