#define SPI2EN (1U<<12)

#define RXNE (1U<<0)
#define TXE  (1U<<1)
#define BUSY  (1U<<7)

#define MSTR (1U<<2)
#define DFF (1U<<11)
#define SPE (1U<<6)


#define RS (1<<10)
#define RW (1<<9)
#define EN (1<<8)

void GPIOA_INIT();
