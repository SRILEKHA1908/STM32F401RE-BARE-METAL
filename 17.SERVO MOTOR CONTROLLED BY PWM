#include"stm32f401xe.h"
#include"stdint.h"

void TIMER2_PWM();
void TIMER2_PWM_RESET();
void TIMER2_PWM_SET();

int main()
{
	TIMER2_PWM();
	while(1)
	{
		TIMER2_PWM_SET();
		for(int i=0;i<1000000;i++);
		TIMER2_PWM_RESET();
		for(int i=0;i<1000000;i++);
	}
}

void TIMER2_PWM()
{
	RCC->AHB1ENR |= (1<<0);

	GPIOA->MODER |= (1<<31);

	GPIOA->AFR[1] |= (1<<28);

	RCC->APB1ENR |= (1<<0);

	TIM2->PSC = 16 - 1 ;//1MHZ FOR GOOD RES

	TIM2->ARR = 20000-1;//20MS

	TIM2->CNT = 0 ;

	TIM2->CCMR1 |= (0X6UL << 4U);

	TIM2->CCER |= (1<<0);

	TIM2->CR1 |= (1<<0);
}


void TIMER2_PWM_SET()
{
	int i;
	TIM2->CCR1 = 1000;  // Initialize duty cycle to 0.
	for(i=0;i<=180;i+=10)
	{
		TIM2->CCR1 = 1000 +(i*1000/180);
		while(!(TIM2->SR & TIM_SR_UIF)); // Wait for update interrupt flag.
		TIM2->SR &= ~TIM_SR_UIF; // Clear the update interrupt flag.
	}
}

void TIMER2_PWM_RESET()
{
	int i;
	TIM2->CCR1 =2000 ; // Initialize duty cycle to 100.
	for(i=180;i>=0;i-=10)
	{
		TIM2->CCR1 = 1000 +(i*1000/180);
		while(!(TIM2->SR & TIM_SR_UIF)); // Wait for update interrupt flag.
		TIM2->SR &= ~TIM_SR_UIF; //Clear the update interrupt flag.
	}
}
